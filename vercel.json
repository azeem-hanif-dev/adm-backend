{
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    }
  ],
    "crons": [
    {
      "path": "/api/campaigns/worker-tick?secret=your_secret_here&batch_size=20",
      "schedule": "*/5 * * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ]
}